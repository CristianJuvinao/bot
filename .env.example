# ══════════════════════════════════════════════════════
#  .env — Variables de entorno del bot de reservas
#  ⚠️  NO subas este archivo a Git (.gitignore lo excluye)
# ══════════════════════════════════════════════════════

# ── Credenciales de acceso ──────────────────────────────────────────────────
BOT_USERNAME=tu_usuario_aqui
BOT_PASSWORD=tu_contraseña_aqui

# ── URLs de la plataforma universitaria ────────────────────────────────────
BOT_BASE_URL=https://tu-plataforma.edu.co
BOT_LOGIN_URL=https://tu-plataforma.edu.co/login
BOT_RESERVAS_URL=https://tu-plataforma.edu.co/cafeteria/reservas
BOT_RESERVAS_PATH=/cafeteria/reservas

# ── Comportamiento del bot ──────────────────────────────────────────────────
# Intervalo entre verificaciones en milisegundos (45000 = 45 segundos)
BOT_POLL_INTERVAL_MS=45000
# Máximo de intentos antes de detener el bot automáticamente
BOT_MAX_INTENTOS=100
# Modo sin cabeza: true = sin ventana visible, false = ventana visible
BOT_HEADLESS=false

# ── Selectores CSS (ajustar según la plataforma) ───────────────────────────
# Inspecciona el HTML de tu plataforma con DevTools (F12) para obtener
# los selectores exactos de cada elemento.
SELECTOR_USERNAME=#username
SELECTOR_PASSWORD=#password
SELECTOR_LOGIN_BTN=button[type="submit"]
SELECTOR_RESERVAR=button:has-text("Reservar")
SELECTOR_CONFIRMAR=button:has-text("Confirmar")
SELECTOR_DISPONIBLE=text=Disponible
